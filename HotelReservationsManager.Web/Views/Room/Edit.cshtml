@model HotelReservationsManager.Data.Models.Room

@{
    ViewData["Title"] = "Редактирай стая";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Number" class="form-label">Номер</label>
        <input asp-for="Number" class="form-control" />
        <span asp-validation-for="Number" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Capacity" class="form-label">Капацитет</label>
        <input asp-for="Capacity" class="form-control" type="number" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Type" class="form-label">Тип</label>
        <select asp-for="Type" class="form-select">
        @foreach (var t in Enum.GetValues(typeof(HotelReservationsManager.Data.Models.RoomType)))
            {
                <option value="@t" selected="@(t.Equals(Model.Type) ? "selected" : null)">@t</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="BedPriceAdult" class="form-label">Цена възрастен</label>
        <input asp-for="BedPriceAdult" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="BedPriceAdult" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="BedPriceYoung" class="form-label">Цена дете/млад</label>
        <input asp-for="BedPriceYoung" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="BedPriceYoung" class="text-danger"></span>
    </div>
    <button class="btn btn-primary">Запази</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
