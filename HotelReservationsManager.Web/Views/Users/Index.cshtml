@using HotelReservationsManager.Data.Models
@model IEnumerable<User>

@{
    ViewData["Title"] = "Потребители";
    var pageSize = ViewBag.PageSize ?? 10;
    var sizes = ViewBag.PageSizeOptions as int[] ?? new[] { 10, 25, 50 };
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Потребители</h2>
            <a asp-action="Create" class="btn btn-primary btn-sm">Нов потребител</a>
        </div>

        <form method="get" class="row g-3 mb-3">
            <div class="col-auto">
                <input type="text" name="search" class="form-control" placeholder="Търси..." />
            </div>
            <div class="col-auto">
                <select name="pageSize" class="form-select">
                    @foreach (var s in sizes)
                    {
                        <option value="@s" selected="@(s == pageSize ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary">Филтрирай</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Потребителско име</th>
                        <th>Име</th>
                        <th>Email</th>
                        <th>Активен</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Username</td>
                            <td>@u.FirstName @u.LastName</td>
                            <td>@u.Email</td>
                            <td>@(u.IsActive ? "Да" : "Не")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-warning me-1" asp-action="Edit" asp-route-id="@u.Id">Редактирай</a>
                                <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@u.Id">Детайли</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, pageSize = pageSize })">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
