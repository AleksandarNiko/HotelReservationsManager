@using HotelReservationsManager.ViewModels
@using HotelReservationsManager.Data.Models
@model ReservationCreateViewModel

@{
    ViewData["Title"] = "Редактирай резервация";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <div>
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    </div>
    <input type="hidden" name="id" value="@ViewBag.ReservationId" />

    <div class="mb-3">
        <label asp-for="RoomId" class="form-label">Стая</label>
        <select asp-for="RoomId" class="form-select select2-single" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Rooms, "Id", "Number"))">
            <option value="">-- Избери стая --</option>
        </select>
        <span asp-validation-for="RoomId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Клиенти</label>
        <select asp-for="SelectedClientIds" class="form-select select2-multiple" multiple size="6" name="SelectedClientIds">
            @foreach (var c in (IEnumerable<Client>)ViewBag.Clients)
            {
                var isSelected = Model.SelectedClientIds.Contains(c.Id);
                <option value="@c.Id" selected="@(isSelected ? "selected" : null)">@c.FirstName @c.LastName (@c.Email)</option>
            }
        </select>
        <span asp-validation-for="SelectedClientIds" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="CheckInDate" class="form-label">Дата на настаняване</label>
            <input asp-for="CheckInDate" class="form-control datepicker" />
            <span asp-validation-for="CheckInDate" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="CheckOutDate" class="form-label">Дата на освобождаване</label>
            <input asp-for="CheckOutDate" class="form-control datepicker" />
            <span asp-validation-for="CheckOutDate" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="HasBreakfast" class="form-check-input" />
        <label asp-for="HasBreakfast" class="form-check-label">Закуска</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsAllInclusive" class="form-check-input" />
        <label asp-for="IsAllInclusive" class="form-check-label">All Inclusive</label>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Откажи</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
