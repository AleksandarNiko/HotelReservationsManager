@using HotelReservationsManager.Data.Models
@model IEnumerable<Reservation>
@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    var sizes = ViewBag.PageSizeOptions as int[] ?? new[] { 10, 25, 50 };
    var search = ViewBag.Search as string ?? "";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="card-title mb-0">Всички Резервации</h2>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn btn-success btn-sm">Нова резервация</a>
            }
        </div>

        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="search" value="@search" class="form-control" placeholder="Търси по клиент..." />
                </div>
                <div class="col-auto">
                    <select name="pageSize" class="form-select">
                        @foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(s == pageSize ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Филтрирай</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Стая №</th>
                        <th>Клиенти</th>
                        <th>Настаняване</th>
                        <th>Освобождаване</th>
                        <th>Закуска</th>
                        <th>All Incl.</th>
                        <th>Сума</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Room?.Number</td>
                            <td>
                                @if (item.Clients != null && item.Clients.Any())
                                {
                                    foreach (var c in item.Clients)
                                    {
                                        <span class="badge bg-secondary me-1">@c.FirstName @c.LastName</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@item.ArrivalDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.DepartureDate.ToString("dd.MM.yyyy")</td>
                            <td>@(item.HasBreakfast ? "Да" : "Не")</td>
                            <td>@(item.IsAllInclusive ? "Да" : "Не")</td>
                            <td class="text-success fw-bold">@item.Sum.ToString("C")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" asp-action="Details" asp-route-id="@item.Id">Детайли</a>
                                <a class="btn btn-sm btn-outline-warning me-1" asp-action="Edit" asp-route-id="@item.Id">Редактирай</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, pageSize = pageSize, search = search })">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
