@using HotelReservationsManager.Data.Models
@model IEnumerable<Reservation>
@{
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<h2>Всички Резервации</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <input type="text" name="search" class="form-control" placeholder="Търси по клиент..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Филтрирай</button>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Стая №</th>
            <th>Настаняване</th>
            <th>Освобождаване</th>
            <th>Сума</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Room.Number</td>
                <td>@item.ArrivalDate.ToShortDateString()</td>
                <td>@item.DepartureDate.ToShortDateString()</td>
                <td>@item.Sum.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Детайли</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { pageNumber = i })">@i</a>
            </li>
        }
    </ul>
</nav>
